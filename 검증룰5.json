{
  "version": "2026-06-19",
  "category": "text_quality_and_auxiliary",
  "description": "텍스트 품질과 보조 정보 처리 규칙이다.",
  "rules": [
    {
      "rule_id": "TEXT-001",
      "level": "WARN",
      "title": "치환 문자 포함",
      "api_fields": [
        "GetHotelList.result[].listHotelPlaceData[].address",
        "GetProductDetailInfo.result.includedNote",
        "GetProductDetailInfo.result.unincludedNote"
      ],
      "logic": "문구에 유니코드 치환 문자나 깨진 문자가 포함되면 경고다."
    },
    {
      "rule_id": "AIR-REMARK-001",
      "level": "INFO",
      "title": "항공 부가 안내는 보조 데이터",
      "api_fields": [
        "GetFlightRemarkList.result[].infoName",
        "GetFlightRemarkList.result[].remark"
      ],
      "logic": "수하물, 좌석, 체크인, 기내서비스 정보는 구조 오류보다 보조 설명 데이터로 우선 사용한다."
    },
    {
      "rule_id": "COUPON-001",
      "level": "INFO",
      "title": "쿠폰 정보는 참고 정보",
      "api_fields": [
        "GetPackageCouponList.result[]"
      ],
      "logic": "쿠폰 정보는 텍스트 품질이나 구조 검수의 핵심 오류보다 부가 정보로 취급한다."
    }
  ]
}

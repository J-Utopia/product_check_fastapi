{
  "version": "2026-06-18",
  "category": "text_quality_and_auxiliary",
  "description": "문자 품질과 보조 검증 규칙",
  "rules": [
    {
      "rule_id": "TEXT-001",
      "level": "WARN",
      "title": "치환 문자 포함",
      "api_fields": [
        "GetHotelList.result[].listHotelPlaceData[].address",
        "GetProductDetailInfo.result.includedNote",
        "GetProductDetailInfo.result.unincludedNote"
      ],
      "logic": "문구에 유니코드 치환 문자(�)가 포함되면 경고"
    },
    {
      "rule_id": "AIR-REMARK-001",
      "level": "INFO",
      "title": "항공 부가 안내 수집",
      "api_fields": [
        "GetFlightRemarkList.result[].infoName",
        "GetFlightRemarkList.result[].remark"
      ],
      "logic": "수하물/좌석/체크인 정보는 오류보다 보조 설명 데이터로 우선 활용"
    },
    {
      "rule_id": "COUPON-001",
      "level": "INFO",
      "title": "쿠폰 존재 여부 참고",
      "api_fields": [
        "GetPackageCouponList.result[]"
      ],
      "logic": "쿠폰 정보는 품질 검수 핵심 오류보다 부가 정보로 취급"
    }
  ]
}

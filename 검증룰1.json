{
  "version": "2026-06-19",
  "category": "title_period_air",
  "description": "제목, 기간, 직항/노옵션/노쇼핑/노팁 계열 문구와 API 핵심값의 충돌을 검증한다.",
  "rules": [
    {
      "rule_id": "TITLE-001",
      "level": "ERROR",
      "title": "제목 박수/일수 불일치",
      "api_fields": [
        "GetPackageInfo.result.date.night",
        "GetPackageInfo.result.date.days",
        "GetProductDetailInfo.result.productName"
      ],
      "logic": "제목의 N박 M일 표기가 API의 nights/days와 다르면 오류다."
    },
    {
      "rule_id": "TITLE-002",
      "level": "ERROR",
      "title": "노쇼핑 문구 불일치",
      "api_fields": [
        "GetPackageInfo.result.shoppingCount",
        "GetProductDetailInfo.result.shoppingTimes",
        "GetProductDetailInfo.result.productName"
      ],
      "logic": "제목이나 배지에 노쇼핑 문구가 있는데 쇼핑 횟수가 1 이상이면 오류다."
    },
    {
      "rule_id": "TITLE-003",
      "level": "ERROR",
      "title": "노옵션 문구 불일치",
      "api_fields": [
        "GetProductDetailInfo.result.optionalTourOrNot",
        "GetProductDetailInfo.result.productName"
      ],
      "logic": "제목이나 배지에 노옵션 문구가 있는데 optionalTourOrNot=Y 이면 오류다."
    },
    {
      "rule_id": "TITLE-004",
      "level": "ERROR",
      "title": "노팁/노기사경비 문구 불일치",
      "api_fields": [
        "GetProductDetailInfo.result.includedNote",
        "GetProductDetailInfo.result.unincludedNote",
        "GetProductDetailInfo.result.productName"
      ],
      "logic": "노팁, NO팁, 노기사경비, NO기사가이드경비 문구가 있는데 불포함에 필수 가이드/기사 경비가 남아 있으면 오류다. 매너팁, 마사지팁, 식당팁 같은 선택성 팁은 예외로 본다."
    },
    {
      "rule_id": "AIR-001",
      "level": "ERROR",
      "title": "직항 문구 불일치",
      "api_fields": [
        "GetProductDetailInfo.result.directFlightOrNot",
        "GetProductDetailInfo.result.productName"
      ],
      "logic": "제목이나 배지에 직항 문구가 있는데 directFlightOrNot=N 이면 오류다."
    }
  ]
}

{
  "version": "2026-06-18",
  "category": "hotel_meeting_guide",
  "description": "숙박, 미팅, 가이드 관련 교차검증",
  "rules": [
    {
      "rule_id": "HOTEL-001",
      "level": "WARN",
      "title": "숙박 박수 확인 필요",
      "api_fields": [
        "GetPackageInfo.result.date.night",
        "GetHotelList.result[].first"
      ],
      "logic": "호텔 API에 나타난 숙박 일차 수가 상품 박수와 다르면 경고. 기내박/야간이동 예외를 고려한다."
    },
    {
      "rule_id": "MEETING-001",
      "level": "WARN",
      "title": "미팅시간 누락 가능성",
      "api_fields": [
        "GetProductDetailInfo.result.meetingTime",
        "GetProductDetailInfo.result.meetingPlace2"
      ],
      "logic": "미팅 장소 안내는 있는데 meetingTime이 비어 있으면 경고"
    },
    {
      "rule_id": "GUIDE-001",
      "level": "WARN",
      "title": "가이드 표기 상충",
      "api_fields": [
        "GetPackageInfo.result.guideYn",
        "GetProductKeyPointInfo.result.leaderGuildStatus"
      ],
      "logic": "guideYn=Y 인데 핵심포인트 가이드 상태가 없음이면 경고"
    }
  ]
}

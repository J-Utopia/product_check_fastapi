{
  "openapi": "3.1.0",
  "info": {
    "title": "Modetour Itinerary Inspection API",
    "version": "2.0.0",
    "description": "모두투어 상품 일정표 검수 결과를 반환하는 API"
  },
  "servers": [
    {
      "url": "https://product-check-fastapi.onrender.com"
    }
  ],
  "paths": {
    "/run-itinerary": {
      "post": {
        "operationId": "runItinerary",
        "summary": "group_id 기준 일정표 검수",
        "parameters": [
          {
            "name": "compact",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "true면 GPTs용 경량 응답 반환"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunItineraryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "검수 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompactInspectionEnvelope"
                }
              }
            }
          },
          "502": {
            "description": "ModeTour API 호출 실패",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "503": {
            "description": "인증 헤더 수집 실패",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RunItineraryRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "group_id": {
            "type": "string",
            "description": "상품 또는 그룹 식별자"
          }
        },
        "required": ["group_id"]
      },
      "CompactInspectionEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "group_id": {
            "type": "string"
          },
          "meta": {
            "$ref": "#/components/schemas/MetaObject"
          },
          "result": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CompactInspectionPayload"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": ["status", "code", "message", "group_id", "meta"]
      },
      "ErrorEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "status": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "group_id": {
            "type": "string"
          },
          "meta": {
            "$ref": "#/components/schemas/MetaObject"
          },
          "result": {
            "type": "null"
          }
        },
        "required": ["status", "code", "message", "group_id", "meta", "result"]
      },
      "MetaObject": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "prices": {
            "type": "object",
            "additionalProperties": {
              "type": ["integer", "null"]
            }
          }
        }
      },
      "CompactInspectionPayload": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "summary": {
            "type": "string"
          },
          "normalized": {
            "$ref": "#/components/schemas/CompactNormalizedProduct"
          },
          "issues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompactIssue"
            }
          },
          "quality": {
            "$ref": "#/components/schemas/QualityScore"
          }
        },
        "required": ["summary", "normalized", "issues", "quality"]
      },
      "CompactNormalizedProduct": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "product_no": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "departure_date": {
            "type": ["string", "null"]
          },
          "arrival_date": {
            "type": ["string", "null"]
          },
          "nights": {
            "type": ["integer", "null"]
          },
          "days": {
            "type": ["integer", "null"]
          },
          "country_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "city_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "top_badges": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hashtags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "included_items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "excluded_items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "departure_airline_name": {
            "type": ["string", "null"]
          },
          "return_airline_name": {
            "type": ["string", "null"]
          },
          "departure_flight": {
            "type": ["string", "null"]
          },
          "return_flight": {
            "type": ["string", "null"]
          },
          "direct_flight": {
            "type": ["boolean", "null"]
          },
          "shopping_count": {
            "type": ["integer", "null"]
          },
          "optional_tour_or_not": {
            "type": ["string", "null"]
          },
          "local_required_expense_or_not": {
            "type": ["string", "null"]
          },
          "local_required_expense": {
            "type": ["integer", "null"]
          },
          "special_benefits": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sightseeings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "key_point_hotels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "key_point_meals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "key_point_leader_guild": {
            "type": "string"
          },
          "display_price_adult": {
            "type": ["integer", "null"]
          },
          "selling_price_adult": {
            "type": ["integer", "null"]
          },
          "selling_price_child_no_bed": {
            "type": ["integer", "null"]
          },
          "selling_price_child_extra_bed": {
            "type": ["integer", "null"]
          },
          "selling_price_infant": {
            "type": ["integer", "null"]
          },
          "coupon_count": {
            "type": "integer"
          },
          "coupon_titles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hotels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "air_segments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompactFlightSummary"
            }
          },
          "schedule_days": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompactDaySummary"
            }
          }
        },
        "required": ["product_no", "product_name", "title"]
      },
      "CompactIssue": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "level": {
            "type": "string",
            "enum": ["FATAL", "ERROR", "WARN", "INFO"]
          },
          "title": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompactEvidenceItem"
            }
          }
        },
        "required": ["rule_id", "level", "title", "message", "suggestion"]
      },
      "CompactEvidenceItem": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "field": {
            "type": "string"
          },
          "value_excerpt": {
            "type": "string"
          }
        },
        "required": ["field", "value_excerpt"]
      },
      "CompactFlightSummary": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "direction": {
            "type": "string"
          },
          "flight_no": {
            "type": ["string", "null"]
          },
          "departure_city_name": {
            "type": ["string", "null"]
          },
          "departure_time": {
            "type": ["string", "null"]
          },
          "arrival_city_name": {
            "type": ["string", "null"]
          },
          "arrival_time": {
            "type": ["string", "null"]
          }
        },
        "required": ["direction"]
      },
      "CompactDaySummary": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "day_no": {
            "type": "integer"
          },
          "date": {
            "type": ["string", "null"]
          },
          "route_headers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "place_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "highlights": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["day_no", "route_headers", "place_names", "highlights"]
      },
      "QualityScore": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "score": {
            "type": "integer"
          },
          "grade": {
            "type": "string"
          }
        },
        "required": ["score", "grade"]
      }
    }
  }
}
